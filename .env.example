# Copy to .env and edit. Everything here is optional — with no .env at all
# you get the kokoro-only stack with default voices.

# Run the container as the desktop user who owns the audio session
# (defaults to 1000; check with `id -u`).
#UID=1000
#GID=1000

# Enable the supertonic engine (adds the supertonic container; requires the
# model assets — see README).
#COMPOSE_PROFILES=supertonic

# Engine used when a request doesn't name one: kokoro, supertonic, or
# random (per-request pick among all engines, falling back to the next if
# the picked one is down).
#ENGINE=kokoro

# Default voice per engine.
#VOICE=af_heart
#SUPERTONIC_VOICE=M1
